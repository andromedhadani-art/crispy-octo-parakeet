<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My First Website</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <!-- Navigation Bar -->
    <nav class="navbar">
        <div class="nav-container">
            <h1 class="logo">MyWebsite</h1>
            <ul class="nav-menu">
                <li><a href="#home" class="nav-link">Home</a></li>
                <li><a href="#about" class="nav-link">About</a></li>
                <li><a href="#services" class="nav-link">Services</a></li>
                <li><a href="#contact" class="nav-link">Contact</a></li>
            </ul>
        </div>
    </nav>

    <!-- Hero Section -->
    <section id="home" class="hero">
        <div class="hero-content">
            <h1>Welcome to My Website</h1>
            <p>Learn web development and build amazing websites</p>
            <button class="btn" onclick="scrollToSection('about')">Get Started</button>
        </div>
    </section>

    <!-- About Section -->
    <section id="about" class="about">
        <div class="container">
            <h2>About Us</h2>
            <p>
                This is a simple website template perfect for beginners learning web development. 
                It includes HTML structure, CSS styling, and basic JavaScript interactivity.
            </p>
            <div class="features">
                <div class="feature-box">
                    <h3>📱 Responsive</h3>
                    <p>Works on all devices</p>
                </div>
                <div class="feature-box">
                    <h3>🎨 Modern Design</h3>
                    <p>Clean and professional look</p>
                </div>
                <div class="feature-box">
                    <h3>⚡ Fast</h3>
                    <p>Optimized for speed</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Services Section -->
    <section id="services" class="services">
        <div class="container">
            <h2>Our Services</h2>
            <div class="services-grid">
                <div class="service-card">
                    <h3>Web Design</h3>
                    <p>Beautiful and functional website designs</p>
                </div>
                <div class="service-card">
                    <h3>Development</h3>
                    <p>Building responsive and interactive websites</p>
                </div>
                <div class="service-card">
                    <h3>Support</h3>
                    <p>24/7 customer support and maintenance</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="contact">
        <div class="container">
            <h2>Get In Touch</h2>
            <form class="contact-form" onsubmit="handleSubmit(event)">
                <input type="text" placeholder="Your Name" required>
                <input type="email" placeholder="Your Email" required>
                <textarea placeholder="Your Message" rows="5" required></textarea>
                <button type="submit" class="btn">Send Message</button>
            </form>
        </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <p>&copy; 2024 My Website. All rights reserved.</p>
            <div class="social-links">
                <a href="#" class="social-link">Facebook</a>
                <a href="#" class="social-link">Twitter</a>
                <a href="#" class="social-link">Instagram</a>
            </div>
        </div>
    </footer>

    <script src="script.js"></script>
</body>
</html>
